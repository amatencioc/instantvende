# ============================================================
# InstantVende — Backend (.env)
# Copia este archivo como .env y rellena los valores
# ============================================================

# === SEGURIDAD (REQUERIDO) ===
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=cambia_esto_por_una_clave_segura

# === BASE DE DATOS ===
DATABASE_URL=sqlite:///./instantvende.db

# === OLLAMA / IA ===
OLLAMA_MODEL=phi3:mini
# Timeout para respuesta de Ollama (segundos) — aumentar si el modelo es lento
# phi3:mini en CPU puede tardar 60-120 segundos; con GPU 5-15 segundos
OLLAMA_TIMEOUT=120

# === CORS ===
# Orígenes permitidos separados por comas.
# DESARROLLO: usar localhost. PRODUCCIÓN: cambiar a tu dominio real.
# Ejemplo producción: CORS_ORIGINS=https://tudominio.com,https://admin.tudominio.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# === BACKUPS ===
BACKUP_INTERVAL_HOURS=6
MAX_BACKUPS=10

# === BOT / NEGOCIO ===
# Nombre del vendedor que se muestra en el chat
BOT_NAME=Favio
# Nombre del negocio (aparece en catálogo, saludos, ubicación)
STORE_NAME=Fresh Boy Store
# Dirección física de la tienda
STORE_ADDRESS=Av. Principal 123, Miraflores, Lima

# === ENVÍOS (en centavos; S/ 10 = 1000, S/ 15 = 1500, S/ 80 = 8000) ===
SHIPPING_LIMA_CENTS=1000
SHIPPING_PROVINCES_CENTS=1500
SHIPPING_FREE_THRESHOLD_CENTS=8000

# === HORARIOS DE ATENCIÓN ===
SCHEDULE_WEEKDAY=Lun - Vie: 9:00 AM - 8:00 PM
SCHEDULE_SATURDAY=Sábados: 10:00 AM - 6:00 PM

# === DESCUENTOS (porcentaje) ===
DISCOUNT_TWO_PRODUCTS_PCT=10
DISCOUNT_THREE_PLUS_PCT=15

# === BOT TUNING ===
# Número de mensajes del historial que se pasan a la IA
HISTORY_MESSAGES_LIMIT=6
# Máximo de productos que se incluyen en el contexto de la IA
AI_MAX_PRODUCTS_CONTEXT=8
# Máximo de productos en recomendaciones
AI_MAX_RECOMMENDATIONS=3
# Segundos mínimos entre mensajes del mismo número (rate limiting)
MESSAGE_COOLDOWN_SECONDS=1.5
# Máximo de caracteres en la respuesta de la IA antes de truncar
AI_RESPONSE_MAX_CHARS=1000

# === BOT PROFILE ===
# Ruta al archivo bot_profile.json (dejar vacío para usar el default del backend)
# BOT_PROFILE_PATH=./backend/bot_profile.json
