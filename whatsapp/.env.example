# ============================================================
# InstantVende — Cliente WhatsApp (.env)
# Copia este archivo como .env y rellena los valores
# ============================================================

# === BACKEND ===
BACKEND_URL=http://localhost:8000

# === SEGURIDAD (REQUERIDO) ===
# Debe coincidir con API_SECRET_KEY del backend
BACKEND_API_KEY=cambia_esto_por_una_clave_segura

# === NOMBRE DEL NEGOCIO ===
BUSINESS_NAME=InstantVende

# === TIMEOUTS ===
# Tiempo máximo (ms) esperando respuesta de la IA
AI_TIMEOUT_MS=90000
# Intervalo (ms) para refrescar el indicador "escribiendo..."
TYPING_DELAY_MS=3000
