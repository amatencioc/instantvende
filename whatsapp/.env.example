# ============================================================
# InstantVende — Cliente WhatsApp (.env)
# Copia este archivo como .env y rellena los valores
# ============================================================

# === BACKEND ===
BACKEND_URL=http://localhost:8000

# === SEGURIDAD (REQUERIDO) ===
# API key única del vendor — se obtiene al registrar/iniciar sesión:
#   POST /api/vendors/login  →  { "api_key": "..." }
# Cada vendor tiene su propia clave; NUNCA compartas esta clave entre vendors.
BACKEND_API_KEY=pega_aqui_la_api_key_de_tu_vendor

# === NOMBRE DEL NEGOCIO ===
BUSINESS_NAME=InstantVende

# === TIMEOUTS ===
# Tiempo máximo (ms) esperando respuesta de la IA
AI_TIMEOUT_MS=90000
# Intervalo (ms) para refrescar el indicador "escribiendo..."
TYPING_DELAY_MS=3000

# === REINTENTOS ===
# Número de reintentos ante errores de red (ECONNREFUSED, ECONNRESET)
MAX_RETRIES=2
# Delay (ms) antes de intentar reconectar tras una desconexión
RECONNECT_DELAY_MS=5000

# === MENSAJES DE ERROR (configurables) ===
ERROR_MSG_TIMEOUT=Disculpa la demora 🙏 Escribe *#catalogo* para ver nuestros productos.
ERROR_MSG_GENERAL=Disculpa, tuve un problema técnico. Escribe *#ayuda* para los comandos. 🙏

# === WHATSAPP ===
# Ruta donde se guarda la sesión de WhatsApp
# Para múltiples vendors, usa rutas diferentes: ./whatsapp-session-vendor1, etc.
WHATSAPP_SESSION_PATH=./whatsapp-session
# Máximo de caracteres por mensaje antes de dividirlo automáticamente
MAX_MSG_LENGTH=3500

# === PUERTO DEL SERVIDOR HTTP LOCAL ===
# Para múltiples vendors, cada cliente WA usa un puerto diferente: 3001, 3002, etc.
WA_HTTP_PORT=3001
